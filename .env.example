# Application URL
# IMPORTANT: Set this in Vercel Environment Variables to ensure MCP tools generate
# correct URLs across all deployments (prevents preview URLs in production)
NEXT_PUBLIC_APP_URL=https://rfp-analyzer-ashy.vercel.app

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Application Environment
NODE_ENV=development

# N8N Webhooks for AI Analysis
N8N_WEBHOOK_TEST=https://n8n.example.com/webhook-test/your-test-id
N8N_WEBHOOK_PROD=https://n8n.example.com/webhook/your-prod-id
N8N_DEFENSE_ANALYSIS_WEBHOOK_URL=https://n8n.example.com/webhook/your-defense-analysis-id
N8N_PRESENTATION_ANALYSIS_WEBHOOK_URL=https://n8n.example.com/webhook/your-presentation-analysis-id
N8N_SOUTENANCE_WEBHOOK_URL=https://n8n.example.com/webhook/your-soutenance-id
N8N_TRANSCRIPTION_WEBHOOK_URL=https://n8n.example.com/webhook/your-transcription-id
N8N_WEBHOOK_TOKEN=your-secret-token-here

# Vertex AI Search Configuration
GCP_VERTEX_AI_PROJECT_NUMBER=895472224132
GCP_VERTEX_AI_LOCATION=global
GCP_VERTEX_AI_ENGINE_ID=rfp-rag-1772536484
GCP_VERTEX_AI_DATA_STORE_ID=rfps_1772495157302_gcs_store
